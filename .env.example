# Anobyte Environment Variables Example
# Duplicate this file as '.env' and provide your Supabase configurations.
# If these variables are not provided, Anobyte automatically operates in a high-fidelity local Sandbox Mode.

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only values. Configure these in Vercel Project Settings, never in client code.
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL="Sharing It <hello@yourdomain.com>"
UNSUBSCRIBE_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
APP_URL=https://sharingit.anobyte.online
